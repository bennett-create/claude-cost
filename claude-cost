#!/usr/bin/env python3
"""claude-cost — live $ tracker for Claude Code, from local session logs.

Usage:
  claude-cost                 live terminal dashboard (refreshes every 2s)
  claude-cost --once          print one snapshot and exit
  claude-cost --serve [PORT]  local web dashboard (default port 4477)
  claude-cost --install-sidecar   auto-start the web dashboard at login (macOS)
  claude-cost --since YYYY-MM-DD  manually set the date billing started
  claude-cost --limit 50        kill switch: hard-stop Claude Code at $50/month
  claude-cost --limit-hour 5    hard-stop at $5 charged in any rolling 60 minutes
  claude-cost --limit-prompt 2  hard-stop a single prompt/turn that exceeds $2
  claude-cost --limit[-hour|-prompt] off   remove that limit
  claude-cost --approve [N]     approve $N (default 10) extra for this month
  claude-cost --snooze [MIN]    waive hourly+per-prompt limits for MIN (default 15) minutes
  claude-cost --gate            budget check for Claude Code hooks (exit 2 = block)
  claude-cost --install-gate    wire the kill-switch hooks into ~/.claude/settings.json

Subscription handling: Claude Code logs don't mark individual messages as
subscription-covered vs API-billed. Instead we read billingType from
~/.claude.json — while it's a subscription, usage counts as $0 charged.
When billing flips to per-token, the cutover time is stored in
~/.config/claude-cost/state.json and only usage after it counts as charged.
"""
import glob
import json
import os
import re
import sys
import time
from collections import defaultdict
from datetime import datetime, timedelta, timezone

PROJECTS_DIR = os.path.expanduser("~/.claude/projects")
CLAUDE_JSON = os.path.expanduser("~/.claude.json")
STATE_DIR = os.path.expanduser("~/.config/claude-cost")
STATE_FILE = os.path.join(STATE_DIR, "state.json")
DEFAULT_PORT = 4477

# $ per 1M tokens: (input, output).
EXACT_PRICING = {
    "claude-fable-5": (10.00, 50.00),
    "claude-mythos-5": (10.00, 50.00),
    "claude-opus-4-8": (5.00, 25.00),
    "claude-opus-4-7": (5.00, 25.00),
    "claude-opus-4-6": (5.00, 25.00),
    "claude-sonnet-4-6": (3.00, 15.00),
    "claude-haiku-4-5": (1.00, 5.00),
}
_today = datetime.now(timezone.utc).date()
EXACT_PRICING["claude-sonnet-5"] = (
    (2.00, 10.00) if _today <= datetime(2026, 8, 31).date() else (3.00, 15.00)
)
FALLBACK_TIERS = [("opus", (5.00, 25.00)), ("sonnet", (3.00, 15.00)), ("haiku", (1.00, 5.00))]

_unknown_models = set()


# ---------- pricing ----------

def price_for(model):
    if model in EXACT_PRICING:
        return EXACT_PRICING[model], True
    stripped = re.sub(r"-\d{8}$", "", model)
    if stripped in EXACT_PRICING:
        return EXACT_PRICING[stripped], True
    for needle, price in FALLBACK_TIERS:
        if needle in model:
            return price, False
    return (5.00, 25.00), False


def cost_for_usage(model, usage):
    (in_p, out_p), exact = price_for(model)
    if not exact:
        _unknown_models.add(model)
    cc = usage.get("cache_creation") or {}
    w5 = cc.get("ephemeral_5m_input_tokens")
    w1 = cc.get("ephemeral_1h_input_tokens")
    if w5 is None and w1 is None:
        w5, w1 = usage.get("cache_creation_input_tokens", 0) or 0, 0
    return (
        (usage.get("input_tokens", 0) or 0) * in_p
        + (usage.get("output_tokens", 0) or 0) * out_p
        + (usage.get("cache_read_input_tokens", 0) or 0) * in_p * 0.1
        + (w5 or 0) * in_p * 1.25
        + (w1 or 0) * in_p * 2.0
    ) / 1_000_000


# ---------- billing state ----------

def load_state():
    try:
        with open(STATE_FILE) as f:
            return json.load(f)
    except Exception:
        return {}


def save_state(state):
    os.makedirs(STATE_DIR, exist_ok=True)
    with open(STATE_FILE, "w") as f:
        json.dump(state, f, indent=2)


def current_billing_type():
    try:
        with open(CLAUDE_JSON) as f:
            return (json.load(f).get("oauthAccount") or {}).get("billingType", "")
    except Exception:
        return ""


def billed_since(state):
    """Return ISO timestamp after which usage is charged, or None if on subscription."""
    if state.get("billed_since"):
        return state["billed_since"]
    bt = current_billing_type()
    if bt and "subscription" not in bt:
        # Billing flipped to per-token: record the cutover permanently.
        state["billed_since"] = datetime.now(timezone.utc).isoformat()
        save_state(state)
        return state["billed_since"]
    return None


# ---------- budget gate (kill switch) ----------

GATE_CACHE = os.path.join(STATE_DIR, "gate_cache.json")


def _month_of(ts):
    return ts[:7] if ts else datetime.now().strftime("%Y-%m")


def _is_user_prompt(d):
    """True if a raw log record is a real user prompt (not a tool_result turn)."""
    if d.get("type") != "user" or d.get("isSidechain"):
        return False
    content = (d.get("message") or {}).get("content")
    if isinstance(content, str):
        return True
    if isinstance(content, list):
        return any(isinstance(b, dict) and b.get("type") == "text" for b in content)
    return False


def gate_scan(since):
    """Incremental scan. Returns (month_total, hour_total, files) — also tracks
    per-file spend since the last user prompt and a rolling last-hour event list."""
    try:
        with open(GATE_CACHE) as f:
            cache = json.load(f)
    except Exception:
        cache = {"files": {}}
    files = cache.setdefault("files", {})
    recent = cache.setdefault("recent", [])  # [iso_ts, cost] pairs, pruned to 1h
    for path in iter_jsonl():
        ent = files.setdefault(path, {"offset": 0, "months": {}, "prompt_spend": 0.0})
        try:
            size = os.path.getsize(path)
        except OSError:
            continue
        if size < ent["offset"]:
            ent.update(offset=0, months={}, prompt_spend=0.0)
        if size == ent["offset"]:
            continue
        with open(path, errors="ignore") as f:
            f.seek(ent["offset"])
            chunk = f.read()
            ent["offset"] = f.tell()
        for line in chunk.split("\n"):
            line = line.strip()
            if not line:
                continue
            try:
                d = json.loads(line)
            except json.JSONDecodeError:
                continue
            if _is_user_prompt(d):
                ent["prompt_spend"] = 0.0  # new prompt starts a fresh per-prompt budget
                continue
            rec = parse_record(line)
            if not rec:
                continue
            if since and rec["timestamp"] >= since:
                c = cost_for_usage(rec["model"], rec["usage"])
                m = _month_of(rec["timestamp"])
                ent["months"][m] = ent["months"].get(m, 0.0) + c
                ent["prompt_spend"] = ent.get("prompt_spend", 0.0) + c
                recent.append([rec["timestamp"], c])
    hour_ago = datetime.now(timezone.utc).timestamp() - 3600
    kept = []
    hour_total = 0.0
    for ts, c in recent:
        try:
            t = datetime.fromisoformat(ts.replace("Z", "+00:00")).timestamp()
        except ValueError:
            continue
        if t >= hour_ago:
            kept.append([ts, c])
            hour_total += c
    cache["recent"] = kept
    os.makedirs(STATE_DIR, exist_ok=True)
    tmp = GATE_CACHE + ".tmp"
    with open(tmp, "w") as f:
        json.dump(cache, f)
    os.replace(tmp, GATE_CACHE)
    month = datetime.now().strftime("%Y-%m")
    month_total = sum(ent["months"].get(month, 0.0) for ent in files.values())
    return month_total, hour_total, files


def _read_hook_input():
    if sys.stdin.isatty():
        return {}
    try:
        return json.loads(sys.stdin.read() or "{}")
    except (json.JSONDecodeError, OSError):
        return {}


def _block(msg):
    sys.stderr.write(msg)
    sys.exit(2)


def run_gate(state):
    """Exit 0 if within budget, exit 2 (blocking) if any limit is hit."""
    limit_month = state.get("limit")
    limit_hour = state.get("limit_hour")
    limit_prompt = state.get("limit_prompt")
    if not (limit_month or limit_hour or limit_prompt):
        sys.exit(0)
    since = billed_since(state)
    if not since:
        sys.exit(0)  # on subscription — nothing is charged
    info = _read_hook_input()
    month_total, hour_total, files = gate_scan(since)

    # Monthly cap — the hard one; snooze does NOT bypass it.
    if limit_month:
        month = datetime.now().strftime("%Y-%m")
        headroom = (state.get("headroom") or {}).get(month, 0.0)
        effective = limit_month + headroom
        if month_total >= effective:
            _block(
                f"BUDGET KILL SWITCH: ${month_total:,.2f} of ${effective:,.2f} spent this month "
                f"(limit ${limit_month:,.2f}" + (f" + ${headroom:,.2f} approved" if headroom else "") + "). "
                "Claude Code is paused until the user approves more spend.\n"
                "To continue, the user must run in a separate terminal:\n"
                f"  claude-cost --approve 10     # approve $10 more this month\n"
                f"  claude-cost --limit {int(limit_month) * 2}      # or raise the monthly cap\n"
            )

    snoozed = False
    snooze_until = state.get("snooze_until")
    if snooze_until:
        snoozed = datetime.now(timezone.utc) < datetime.fromisoformat(snooze_until)

    # Rolling last-60-minutes cap.
    if limit_hour and not snoozed and hour_total >= limit_hour:
        _block(
            f"HOURLY BUDGET: ${hour_total:,.2f} charged in the last 60 minutes "
            f"(limit ${limit_hour:,.2f}/h). Claude Code is paused.\n"
            "It unblocks by itself as spend rolls out of the window, or the user can run:\n"
            "  claude-cost --snooze 15        # waive hourly/per-prompt limits for 15 min\n"
            f"  claude-cost --limit-hour {int(limit_hour) * 2}     # or raise the hourly cap\n"
        )

    # Per-prompt cap — only mid-turn (PreToolUse); a fresh user prompt resets it.
    session_id = info.get("session_id")
    is_pretooluse = info.get("hook_event_name") == "PreToolUse" or "tool_name" in info
    if limit_prompt and not snoozed and is_pretooluse and session_id:
        for path, ent in files.items():
            if os.path.basename(path).startswith(session_id):
                spend = ent.get("prompt_spend", 0.0)
                if spend >= limit_prompt:
                    _block(
                        f"PER-PROMPT BUDGET: this prompt has cost ${spend:,.2f} "
                        f"(limit ${limit_prompt:,.2f}). Claude is stopped mid-task.\n"
                        "Sending Claude a new message resets the per-prompt budget and continues.\n"
                        "Or the user can run:\n"
                        "  claude-cost --snooze 15          # waive hourly/per-prompt limits for 15 min\n"
                        f"  claude-cost --limit-prompt {limit_prompt * 2:g}    # or raise the cap\n"
                    )
                break
    sys.exit(0)


def install_gate():
    """Merge the budget-gate hooks into ~/.claude/settings.json."""
    settings_path = os.path.expanduser("~/.claude/settings.json")
    try:
        with open(settings_path) as f:
            settings = json.load(f)
    except FileNotFoundError:
        settings = {}
    except json.JSONDecodeError:
        sys.exit(f"{settings_path} is not valid JSON — fix it first, then re-run.")
    script = os.path.realpath(__file__)
    gate_cmd = f"{script} --gate"
    hook = {"type": "command", "command": gate_cmd, "timeout": 15}
    hooks = settings.setdefault("hooks", {})
    changed = False
    for event in ("PreToolUse", "UserPromptSubmit"):
        entries = hooks.setdefault(event, [])
        existing = [h for e in entries for h in e.get("hooks", [])
                    if "claude-cost" in h.get("command", "") and "--gate" in h.get("command", "")]
        if existing:
            print(f"{event}: gate hook already present, leaving as-is.")
            continue
        entries.append({"hooks": [hook]})
        changed = True
        print(f"{event}: gate hook added.")
    if changed:
        with open(settings_path, "w") as f:
            json.dump(settings, f, indent=2)
    print(f"\nKill switch enforcement installed in {settings_path}.")
    print("Set a cap with: claude-cost --limit 50")
    print("If a running Claude Code session doesn't pick it up, open /hooks once or restart it.")


# ---------- log scanning ----------

def iter_jsonl():
    return glob.glob(os.path.join(PROJECTS_DIR, "**", "*.jsonl"), recursive=True)


def parse_record(line):
    line = line.strip()
    if not line:
        return None
    try:
        d = json.loads(line)
    except json.JSONDecodeError:
        return None
    if d.get("type") != "assistant":
        return None
    m = d.get("message") or {}
    if not m.get("usage") or not m.get("model") or m["model"] == "<synthetic>":
        return None
    return {"model": m["model"], "usage": m["usage"], "timestamp": d.get("timestamp") or ""}


class Tracker:
    def __init__(self, since):
        self.since = since  # ISO string or None
        self.offsets = {}
        self.charged = defaultdict(float)   # model -> $ (after cutover)
        self.covered = defaultdict(float)   # model -> $ (subscription-covered)
        self.charged_today = defaultdict(float)

    def scan(self):
        for path in iter_jsonl():
            off = self.offsets.get(path, 0)
            try:
                size = os.path.getsize(path)
            except OSError:
                continue
            if size < off:
                off = 0
            if size == off:
                continue
            with open(path, errors="ignore") as f:
                f.seek(off)
                chunk = f.read()
                self.offsets[path] = f.tell()
            today = datetime.now().strftime("%Y-%m-%d")
            for line in chunk.split("\n"):
                rec = parse_record(line)
                if not rec:
                    continue
                c = cost_for_usage(rec["model"], rec["usage"])
                if self.since and rec["timestamp"] >= self.since:
                    self.charged[rec["model"]] += c
                    if rec["timestamp"][:10] == today:
                        self.charged_today[rec["model"]] += c
                else:
                    self.covered[rec["model"]] += c

    def snapshot(self):
        return {
            "billing_type": current_billing_type() or "unknown",
            "since": self.since,
            "charged_today": sum(self.charged_today.values()),
            "charged_total": sum(self.charged.values()),
            "covered_total": sum(self.covered.values()),
            "by_model_charged": dict(self.charged),
            "by_model_covered": dict(self.covered),
            "estimated_models": sorted(_unknown_models),
        }


# ---------- rendering ----------

def fmt(x):
    return f"${x:,.4f}" if 0 < x < 1 else f"${x:,.2f}"


def render_text(snap):
    lines = []
    lines.append("claude-cost — what you're being charged for Claude Code")
    lines.append(f"billing: {snap['billing_type']}"
                 + (f"   charged since: {snap['since'][:19]}" if snap["since"] else "   (subscription — nothing charged per-token yet)"))
    lines.append("-" * 58)
    if snap["since"]:
        lines.append(f"{'Model':<26}{'Charged today':>15}{'Charged total':>17}")
        lines.append("-" * 58)
        models = sorted(snap["by_model_charged"])
        for m in models:
            lines.append(f"{m:<26}{fmt(0.0):>15}{fmt(snap['by_model_charged'][m]):>17}")
        lines.append("-" * 58)
        lines.append(f"{'CHARGED':<26}{fmt(snap['charged_today']):>15}{fmt(snap['charged_total']):>17}")
    else:
        lines.append(f"{'CHARGED (real money)':<38}{fmt(0.0):>18}")
    lines.append(f"{'covered by subscription (reference)':<38}{fmt(snap['covered_total']):>18}")
    if snap["estimated_models"]:
        lines.append(f"~ estimated pricing for: {', '.join(snap['estimated_models'])}")
    return "\n".join(lines)


def render_html(snap):
    rows = "".join(
        f"<tr><td>{m}</td><td class='n'>{fmt(v)}</td></tr>"
        for m, v in sorted(snap["by_model_charged"].items())
    ) or "<tr><td colspan=2>nothing charged yet</td></tr>"
    status = (f"charged since {snap['since'][:19]}" if snap["since"]
              else "subscription — nothing charged per-token yet")
    return f"""<!doctype html><html><head><meta charset="utf-8">
<meta http-equiv="refresh" content="5"><title>claude-cost</title>
<style>
 @font-face{{font-family:'Geist Mono';font-style:normal;font-weight:100 900;font-display:swap;
   src:url(https://cdn.jsdelivr.net/npm/geist@1/dist/fonts/geist-mono/GeistMono-Variable.woff2) format('woff2')}}
 body{{font:14px/1.5 'Geist Mono',ui-monospace,monospace;max-width:520px;margin:3rem auto;padding:0 1rem;
      background:#111;color:#ddd;-webkit-font-smoothing:none;font-smooth:never}}
 h1{{font-size:16px}} .big{{font-size:34px;font-weight:700;color:#7fd77f}}
 table{{width:100%;border-collapse:collapse;margin-top:1rem}}
 td{{padding:4px 0;border-bottom:1px solid #333}} .n{{text-align:right}}
 .dim{{color:#888;font-size:12px}}
</style></head><body>
<h1>claude-cost</h1>
<div class="dim">{snap['billing_type']} · {status}</div>
<div class="big">{fmt(snap['charged_total'])}</div>
<div class="dim">charged total · today: {fmt(snap['charged_today'])}
 · subscription-covered (not charged): {fmt(snap['covered_total'])}</div>
<table>{rows}</table>
<div class="dim" style="margin-top:1rem">auto-refreshes every 5s · reads ~/.claude/projects</div>
</body></html>"""


# ---------- modes ----------

def run_tui(tracker, once=False):
    while True:
        tracker.scan()
        out = render_text(tracker.snapshot())
        if once:
            print(out)
            return
        os.system("cls" if os.name == "nt" else "clear")
        print(out + "\n\n(Ctrl-C to stop)")
        time.sleep(2)


def run_serve(tracker, port):
    from http.server import BaseHTTPRequestHandler, HTTPServer

    class H(BaseHTTPRequestHandler):
        def do_GET(self):
            tracker.scan()
            snap = tracker.snapshot()
            if self.path.startswith("/json"):
                body, ctype = json.dumps(snap, indent=2).encode(), "application/json"
            else:
                body, ctype = render_html(snap).encode(), "text/html; charset=utf-8"
            self.send_response(200)
            self.send_header("Content-Type", ctype)
            self.send_header("Content-Length", str(len(body)))
            self.end_headers()
            self.wfile.write(body)

        def log_message(self, *a):
            pass

    print(f"claude-cost sidecar → http://localhost:{port}  (JSON at /json)")
    HTTPServer(("127.0.0.1", port), H).serve_forever()


def install_sidecar(port):
    if sys.platform == "win32":
        # Windows: register a Startup shortcut via a .bat file.
        startup = os.path.join(
            os.environ.get("APPDATA", os.path.expanduser("~")),
            "Microsoft", "Windows", "Start Menu", "Programs", "Startup",
        )
        os.makedirs(startup, exist_ok=True)
        bat = os.path.join(startup, "claude-cost.bat")
        script = os.path.realpath(__file__)
        with open(bat, "w") as f:
            f.write(f'@echo off\nstart "" /min pythonw "{script}" --serve {port}\n')
        os.system(f'start "" /min pythonw "{script}" --serve {port}')
        print(f"Sidecar installed (Startup folder) and started -> http://localhost:{port}")
        print(f"To remove: delete {bat}")
        return
    if sys.platform != "darwin":
        sys.exit("--install-sidecar supports macOS and Windows; on Linux run "
                 f"'claude-cost --serve {port}' under systemd/tmux instead.")
    plist_path = os.path.expanduser("~/Library/LaunchAgents/local.claude-cost.plist")
    script = os.path.realpath(__file__)
    plist = f"""<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0"><dict>
  <key>Label</key><string>local.claude-cost</string>
  <key>ProgramArguments</key><array>
    <string>/usr/bin/python3</string><string>{script}</string>
    <string>--serve</string><string>{port}</string>
  </array>
  <key>RunAtLoad</key><true/>
  <key>KeepAlive</key><true/>
</dict></plist>"""
    with open(plist_path, "w") as f:
        f.write(plist)
    os.system(f"launchctl unload {plist_path} 2>/dev/null; launchctl load {plist_path}")
    print(f"Sidecar installed and started → http://localhost:{port}")
    print(f"To remove: launchctl unload {plist_path} && rm {plist_path}")


def main():
    args = sys.argv[1:]
    state = load_state()

    if "--gate" in args:
        run_gate(state)  # exits

    if "--install-gate" in args:
        install_gate()
        return

    for flag, key, label in (
        ("--limit", "limit", "Monthly spend limit"),
        ("--limit-hour", "limit_hour", "Hourly (rolling 60 min) spend limit"),
        ("--limit-prompt", "limit_prompt", "Per-prompt spend limit"),
    ):
        if flag in args:
            i = args.index(flag)
            val = args[i + 1] if len(args) > i + 1 else "off"
            if val == "off":
                state.pop(key, None)
                print(f"{label} removed.")
            else:
                state[key] = float(val)
                print(f"{label} set to ${float(val):,.2f}. "
                      "Claude Code will hard-stop at the limit (via the budget-gate hook).")
            save_state(state)
            return

    if "--snooze" in args:
        i = args.index("--snooze")
        mins = float(args[i + 1]) if len(args) > i + 1 and args[i + 1].replace(".", "").isdigit() else 15.0
        until = datetime.now(timezone.utc) + timedelta(minutes=mins)
        state["snooze_until"] = until.isoformat()
        save_state(state)
        print(f"Hourly and per-prompt limits waived for {mins:g} minutes "
              f"(until {until.strftime('%H:%M:%S')} UTC). Monthly limit still applies.")
        return

    if "--approve" in args:
        i = args.index("--approve")
        amt = float(args[i + 1]) if len(args) > i + 1 and args[i + 1].replace(".", "").isdigit() else 10.0
        month = datetime.now().strftime("%Y-%m")
        hr = state.setdefault("headroom", {})
        hr[month] = hr.get(month, 0.0) + amt
        save_state(state)
        limit = state.get("limit", 0)
        print(f"Approved ${amt:,.2f} extra for {month}. "
              f"Effective cap this month: ${limit + hr[month]:,.2f}.")
        return

    if "--since" in args:
        i = args.index("--since")
        state["billed_since"] = args[i + 1] + "T00:00:00+00:00" if len(args[i + 1]) == 10 else args[i + 1]
        save_state(state)
        args = args[:i] + args[i + 2:]
        print(f"Charged-usage cutover set to {state['billed_since']}")

    since = billed_since(state)
    tracker = Tracker(since)

    if "--install-sidecar" in args:
        install_sidecar(DEFAULT_PORT)
    elif "--serve" in args:
        i = args.index("--serve")
        port = int(args[i + 1]) if len(args) > i + 1 and args[i + 1].isdigit() else DEFAULT_PORT
        run_serve(tracker, port)
    elif "--once" in args:
        run_tui(tracker, once=True)
    else:
        run_tui(tracker)


if __name__ == "__main__":
    if not os.path.isdir(PROJECTS_DIR):
        sys.exit(f"No Claude Code logs at {PROJECTS_DIR}")
    main()
